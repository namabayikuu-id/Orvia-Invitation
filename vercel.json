{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    {
      "source": "/:slug([^/]+)",
      "destination": "/invitations/:slug/index.html"
    },
    {
      "source": "/:slug([^/]+)/:path+",
      "destination": "/invitations/:slug/:path+"
    }
  ]
}
